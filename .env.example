PORT=4181
REQUIRE_ADMIN_AUTH=1
ADMIN_TOKEN=replace-with-long-random-token
ENABLE_SOREN_BRIDGE=1
OPENCLAW_BIN=/Users/oc/.nvm/versions/node/v22.22.0/bin/openclaw
SOREN_SESSION_ID=clawbell-public-v0
SOREN_BRIDGE_URL=https://example-bridge/ask
SOREN_BRIDGE_TOKEN=replace-with-long-random-token
# Optional when the bridge hostname is protected by Cloudflare Access.
SOREN_BRIDGE_ACCESS_CLIENT_ID=
SOREN_BRIDGE_ACCESS_CLIENT_SECRET=
MAX_MESSAGE_CHARS=1200
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=12
DATA_DIR=./data
